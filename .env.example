# =========================================================
# Sonic Arbitrage Bot — Environment Variables
# =========================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# ---------------------------------------------------------
# Chain & RPC
# ---------------------------------------------------------
# Comma-separated list of Sonic RPC endpoints.
# The bot will round-robin and fall back on failure.
RPC_URLS=https://rpc.soniclabs.com,https://rpc2.soniclabs.com

# Sonic chain ID (do not change)
CHAIN_ID=146

# ---------------------------------------------------------
# Wallet / Signer
# ---------------------------------------------------------
# DEV ONLY — for production use a hardware signer (see README).
# PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Optional: use a remote signer URL instead of a local private key.
# REMOTE_SIGNER_URL=http://localhost:8545

# ---------------------------------------------------------
# Token Addresses (Sonic Mainnet)
# ---------------------------------------------------------
# USDC on Sonic — verify at https://sonicscan.org or DEX docs
USDC_ADDRESS=0xTODO_USDC_ADDRESS

# Wrapped Sonic (WS) — verify at https://sonicscan.org
WS_ADDRESS=0xTODO_WS_ADDRESS

# Wrapped ETH on Sonic (optional pair)
WETH_ADDRESS=0xTODO_WETH_ADDRESS

# ---------------------------------------------------------
# DEX Pool Addresses
# ---------------------------------------------------------
# Shadow USDC/WS pool address — fetch from shadow.so or on-chain
SHADOW_USDC_WS_POOL=0xTODO_SHADOW_POOL

# Beets/BeethovenX V3 USDC/WS pool ID — fetch from beets.fi API
BEETS_USDC_WS_POOL_ID=0xTODO_BEETS_POOL_ID

# Shadow router address
SHADOW_ROUTER=0xTODO_SHADOW_ROUTER

# Beets Vault address (V3 / Balancer-style vault)
BEETS_VAULT=0xTODO_BEETS_VAULT

# Optional USDC/WETH pools
SHADOW_USDC_WETH_POOL=0xTODO
BEETS_USDC_WETH_POOL_ID=0xTODO

# ---------------------------------------------------------
# Arb Bot Parameters
# ---------------------------------------------------------
# Minimum net profit in USD to execute a trade
MIN_PROFIT_USD=1.0

# Maximum trade size as a fraction of wallet balance (0.0–1.0)
MAX_TRADE_EXPOSURE=0.2

# Maximum slippage tolerance in basis points (100 = 1%)
MAX_SLIPPAGE_BPS=50

# Maximum gas price multiplier vs. network base fee
MAX_GAS_PRICE_MULTIPLIER=2.0

# Maximum daily loss in USD before circuit breaker trips
MAX_DAILY_LOSS_USD=500

# Scanner poll interval in milliseconds
SCAN_INTERVAL_MS=300

# ---------------------------------------------------------
# Idle Rebalancing — hold USDC when no opportunities found
# ---------------------------------------------------------
# Set to "true" to automatically swap non-USDC tokens back to USDC
# whenever the scanner finds no arbitrage opportunities.
REBALANCE_TO_USDC=true

# Minimum USD value of non-USDC holdings required to trigger a rebalance.
# Prevents wasting gas on dust amounts.
MIN_REBALANCE_USD=1.0

# ---------------------------------------------------------
# Dry-run & Simulation
# ---------------------------------------------------------
# Set to "true" to run full pipeline without broadcasting txs
DRY_RUN=true

# ---------------------------------------------------------
# Persistence
# ---------------------------------------------------------
# PostgreSQL connection string
DB_URL=postgresql://arbbot:password@localhost:5432/arbbot

# Redis connection string
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------
# Monitoring
# ---------------------------------------------------------
# Prometheus metrics port
METRICS_PORT=9090

# Backend HTTP port (health, metrics)
HTTP_PORT=3001

# WebSocket port for UI
WS_PORT=3002

# ---------------------------------------------------------
# Alerting (optional)
# ---------------------------------------------------------
# Telegram bot token and chat ID for alerts
# TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
# TELEGRAM_CHAT_ID=YOUR_CHAT_ID

# SMTP config for email alerts (optional)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=password
# ALERT_EMAIL=ops@example.com

# ---------------------------------------------------------
# MEV Relay (optional)
# ---------------------------------------------------------
# Sonic-compatible MEV relay URL (leave blank to disable)
# MEV_RELAY_URL=https://your-mev-relay.example.com

# ---------------------------------------------------------
# Logging
# ---------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json
